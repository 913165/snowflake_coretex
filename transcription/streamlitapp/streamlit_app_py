def format_duration(seconds: float) -> str:
    m, s = divmod(int(seconds), 60)
    return f"{m}m {s:02d}s"


def estimate_duration_seconds(file_size_bytes: int) -> float:
    return file_size_bytes / 32000


def format_size_mb(size_bytes: int) -> str:
    return f"{size_bytes / (1024 * 1024):.1f} MB"


def fig_to_bytes(fig) -> bytes:
    buf = io.BytesIO()
    fig.savefig(buf, format="png", bbox_inches="tight", transparent=True, dpi=150)
    buf.seek(0)
    return buf.read()


def _timestamp(seconds: float) -> str:
    m, s = divmod(int(seconds), 60)
    return f"{m}:{s:02d}"


def _upload_to_stage(uploaded_file) -> str:
    import tempfile, os
    with tempfile.TemporaryDirectory() as tmpdir:
        local_path = os.path.join(tmpdir, uploaded_file.name)
        with open(local_path, "wb") as f:
            f.write(uploaded_file.getvalue())
        session.sql(f"PUT 'file://{local_path}' {STAGE} AUTO_COMPRESS=FALSE OVERWRITE=TRUE").collect()
    return uploaded_file.name


def _transcribe(filename: str) -> dict:
    sql = f"""
    SELECT AI_TRANSCRIBE(
        TO_FILE('{STAGE}', '{filename}'),
        {{'timestamp_granularity': 'speaker'}}
    ) AS result
    """
    row = session.sql(sql).collect()[0]
    raw = row["RESULT"]
    if isinstance(raw, str):
        try:
            return json.loads(raw)
        except json.JSONDecodeError:
            return {"text": raw, "segments": []}
    elif isinstance(raw, dict):
        return raw
    return {"text": str(raw), "segments": []}
    

def _analyze_transcript(transcript_text: str) -> dict:
    prompt = f"""Analyze this call center transcript and return a JSON object with these exact keys:
- "sentiment": one of "positive", "negative", "mixed"
- "topic": one of "Tech Support", "Billing", "Sales", "Complaint", "Refund", "Escalation"
- "topic_confidence": a float between 0 and 1
- "outcome": one of "resolved", "callback", "escalated", "unresolved"
- "professionalism_score": integer 0-100
- "empathy_score": integer 0-100
- "resolution_score": integer 0-100
- "key_phrases": list of 3-6 key phrases from the call
- "agent_assessment": a 1-2 sentence assessment of the agent's performance

Transcript:
{transcript_text[:8000]}

Return ONLY valid JSON, no other text."""

    escaped_prompt = prompt.replace("'", "''")
    sql = f"SELECT SNOWFLAKE.CORTEX.COMPLETE('{LLM_MODEL}', '{escaped_prompt}') AS result"
    row = session.sql(sql).collect()[0]
    raw = row["RESULT"]

    if isinstance(raw, dict):
        text = raw.get("choices", [{}])[0].get("messages", raw.get("message", ""))
        if isinstance(text, str):
            raw = text
        else:
            raw = json.dumps(raw)
    
    if not isinstance(raw, str):
        raw = str(raw)

    try:
        start_idx = raw.find("{")
        end_idx = raw.rfind("}") + 1
        if start_idx >= 0 and end_idx > start_idx:
            return json.loads(raw[start_idx:end_idx])
    except json.JSONDecodeError:
        pass

    return {
        "sentiment": "mixed",
        "topic": "Complaint",
        "topic_confidence": 0.5,
        "outcome": "unresolved",
        "professionalism_score": 50,
        "empathy_score": 50,
        "resolution_score": 50,
        "key_phrases": [],
        "agent_assessment": "Unable to parse analysis.",
    }


def _process_file(uploaded_file) -> dict:
    filename = _upload_to_stage(uploaded_file)
    transcription = _transcribe(filename)

    transcript_text = transcription.get("text", "")
    segments = transcription.get("segments", [])
    turns = []
    for seg in segments:
        label = seg.get("speaker_label", "SPEAKER_00")
        speaker = "Agent" if label == "SPEAKER_00" else "Customer"
        turns.append({
            "speaker": speaker,
            "text": seg.get("text", ""),
            "start": seg.get("start", 0),
            "end": seg.get("end", 0),
        })

    analysis = _analyze_transcript(transcript_text)
    avg = round(
        (int(analysis.get("professionalism_score", 0))
         + int(analysis.get("empathy_score", 0))
         + int(analysis.get("resolution_score", 0))) / 3, 1
    )

    return {
        "filename": filename,
        "transcript": transcript_text,
        "turns": turns,
        "analysis": analysis,
        "avg_score": avg,
    }


def _badge_color(outcome: str) -> str:
    mapping = {
        "resolved": "#00d2a0",
        "callback": "#ffb020",
        "escalated": "#b780ff",
        "unresolved": "#ff4d5e",
    }
    return mapping.get(outcome, "#6c7685")


def _topic_color(topic: str) -> str:
    topic_colors = {
        "Tech Support": "#21c7ff",
        "Billing": "#ff5f77",
        "Sales": "#1dde99",
        "Complaint": "#ff7d93",
        "Refund": "#f0cb4a",
        "Escalation": "#9c74ff",
    }
    return topic_colors.get(topic, "#6f89a8")


